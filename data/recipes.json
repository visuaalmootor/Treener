        "3. Pehme: banaan (või mustikad 150g + mesi 1 spl)",
        "4. Kõva: kaerahelbed 50g",
        "5. Rasv: maapähklivõi 2 spl (lisa viimasena — muidu kleepub põhja)",
        "Blenderda 30–60 sekundit",
        "Joo kohe — kaer paisub ja muutub paksemaks"
      ],
      "subs": [
        {
          "missing": "Banaan",
          "use": "Mustikad 150g + mesi 1 spl"
